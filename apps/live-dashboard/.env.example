# Copy to `.env` and fill in. NEVER commit your real `.env`.

# Data source: "ccxt" (crypto exchanges) or "twelvedata" (stocks/forex/crypto)
VBT_SOURCE=ccxt

# --- ccxt source ---
# Any ccxt-supported exchange id (binance, bybit, kraken, coinbase, ...)
VBT_EXCHANGE=binance
# API credentials (optional for public OHLCV, recommended for higher rate limits)
VBT_API_KEY=
VBT_API_SECRET=

# --- twelvedata source ---
# Get a key at https://twelvedata.com (free tier: 8 req/min, 800/day)
TWELVEDATA_API_KEY=

# Market preset. "saudi" (or "tadawul") loads a built-in labeled Tadawul catalog and
# forces source=twelvedata with exchange=Tadawul. Tadawul data usually requires a paid
# Twelve Data plan. Leave blank for no preset.
#   VBT_MARKET=saudi
VBT_MARKET=

# Optional manual Twelve Data market disambiguation (alternative to VBT_MARKET):
#   VBT_TD_EXCHANGE=Tadawul        # or VBT_TD_MIC=XSAU / VBT_TD_COUNTRY=Saudi Arabia
VBT_TD_EXCHANGE=
VBT_TD_MIC=
VBT_TD_COUNTRY=
# Comma-separated symbol list (overrides any preset/source default)
VBT_SYMBOLS=

# Defaults
VBT_SYMBOL=BTC/USDT
VBT_TIMEFRAME=1m
VBT_LOOKBACK=2 days ago UTC
VBT_REFRESH_MS=15000

# Backtest assumptions
VBT_FEES=0.001
VBT_SLIPPAGE=0.0005
VBT_INIT_CASH=10000

# Server
HOST=127.0.0.1
PORT=8050
