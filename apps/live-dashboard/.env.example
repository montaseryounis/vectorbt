# Copy to `.env` and fill in. NEVER commit your real `.env`.

# Data source: "ccxt" (crypto exchanges) or "twelvedata" (stocks/forex/crypto)
VBT_SOURCE=ccxt

# --- ccxt source ---
# Any ccxt-supported exchange id (binance, bybit, kraken, coinbase, ...)
VBT_EXCHANGE=binance
# API credentials (optional for public OHLCV, recommended for higher rate limits)
VBT_API_KEY=
VBT_API_SECRET=

# --- twelvedata source ---
# Get a key at https://twelvedata.com (free tier: 8 req/min, 800/day)
TWELVEDATA_API_KEY=

# Optional: pick a specific market for Twelve Data symbols. Example — Saudi market
# (Tadawul). Use numeric tickers (Aramco 2222, Al Rajhi 1120, SABIC 2010, STC 7010,
# SNB 1180). Tadawul data usually requires a paid Twelve Data plan.
#   VBT_SOURCE=twelvedata
#   VBT_TD_EXCHANGE=Tadawul        # or VBT_TD_MIC=XSAU / VBT_TD_COUNTRY=Saudi Arabia
#   VBT_SYMBOLS=2222,1120,2010,7010,1180
#   VBT_TIMEFRAME=1day
VBT_TD_EXCHANGE=
VBT_TD_MIC=
VBT_TD_COUNTRY=
# Comma-separated symbol list (overrides the built-in list for the chosen source)
VBT_SYMBOLS=

# Defaults
VBT_SYMBOL=BTC/USDT
VBT_TIMEFRAME=1m
VBT_LOOKBACK=2 days ago UTC
VBT_REFRESH_MS=15000

# Backtest assumptions
VBT_FEES=0.001
VBT_SLIPPAGE=0.0005
VBT_INIT_CASH=10000

# Server
HOST=127.0.0.1
PORT=8050
